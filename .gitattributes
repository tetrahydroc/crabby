# Default to LF line endings on every platform.
# Differential test fixtures byte-compare against expected outputs;
# CRLF on checkout breaks them on Windows runners.
* text=auto eol=lf

# Source extensions: explicit text + LF.
*.rs    text eol=lf
*.gd    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Binary: never line-ending-convert. `.gdc` is Godot bytecode, `.pck`
# is a Godot resource pack, etc. Touching their bytes corrupts them.
*.gdc   binary
*.pck   binary
*.zip   binary
*.vmz   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.bin   binary
